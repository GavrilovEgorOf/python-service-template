APP_NAME=python-service-template
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
REDIS_URL=redis://localhost:6379/0

API_V1_PREFIX=/api/v1
AUTH_DISABLED=false
API_KEY=dev-api-key-change-me

JWT_SECRET_KEY=dev-jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=python-service-template
JWT_AUDIENCE=python-service-template-api

OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=python-service-template
OTEL_INSECURE=true

METRICS_ENABLED=true
METRICS_API_KEY=

CACHE_TTL_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_SECONDS=60

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

AUDIT_LOG_ENABLED=true
AUDIT_LOG_PERSIST=false

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=INFO
LOG_JSON=false
